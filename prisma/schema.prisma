generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

enum ItemStatus {
  AVAILABLE
  RESERVED
  SOLD
  REMOVED
}

enum BookingStatus {
  PENDING
  ACCEPTED
  REJECTED
  CANCELLED
}

model User {
  id           String    @id @default(cuid())
  firstName    String
  lastName     String
  email        String    @unique
  passwordHash String
  role         Role      @default(USER)
  items        Item[]
  bookings     Booking[] @relation("BuyerBookings")
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model Item {
  id          String     @id @default(cuid())
  sellerId    String
  seller      User       @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  name        String
  description String     @db.Text
  price       Decimal    @db.Decimal(10, 2)
  imageUrl    String?
  status      ItemStatus @default(AVAILABLE)
  bookings    Booking[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([sellerId])
  @@index([status])
  @@index([createdAt])
}

model Booking {
  id          String        @id @default(cuid())
  itemId       String
  buyerId      String
  item         Item          @relation(fields: [itemId], references: [id], onDelete: Cascade)
  buyer        User          @relation("BuyerBookings", fields: [buyerId], references: [id], onDelete: Cascade)
  message      String?       @db.Text
  status       BookingStatus @default(PENDING)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([itemId])
  @@index([buyerId])
  @@index([status])
}